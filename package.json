{
  "name": "corre",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@corre/web",
    "dev:mobile": "turbo dev --filter=@corre/mobile",
    "mcp:strava": "node ./tools/mcp/strava/server.mjs",
    "ops:check": "bash ./tools/ops/check-clis.sh",
    "supabase:login": "supabase login",
    "supabase:link": "bash ./tools/ops/supabase-link.sh",
    "supabase:db:push": "supabase db push",
    "supabase:secrets:sync": "bash ./tools/ops/supabase-secrets-sync.sh",
    "supabase:functions:deploy": "bash ./tools/ops/supabase-deploy-functions.sh",
    "stripe:login": "stripe login",
    "stripe:webhooks:list": "bash ./tools/ops/stripe-list-webhooks.sh",
    "stripe:webhooks:provision": "bash ./tools/ops/stripe-provision-webhooks.sh",
    "stripe:webhooks:provision:force": "bash ./tools/ops/stripe-provision-webhooks.sh --force-create",
    "stripe:webhooks:listen": "bash ./tools/ops/stripe-listen.sh remote",
    "stripe:webhooks:listen:local": "bash ./tools/ops/stripe-listen.sh local",
    "stripe:webhooks:trigger": "bash ./tools/ops/stripe-trigger.sh",
    "preflight:mobile": "npm run --workspace=@corre/mobile release:preflight",
    "release:mobile": "npm run --workspace=@corre/mobile release:check",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "expo-dev-client": "~6.0.20"
  }
}
