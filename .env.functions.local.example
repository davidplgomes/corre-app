# Local-only function script env (do not commit actual secrets)
# Copy this file to `.env.functions.local` and keep it private.

# Mark that Edge Function secrets are managed in Supabase dashboard.
FUNCTIONS_SECRETS_MANAGED_IN_SUPABASE=true

# Optional: if you want local scripts/tests to use a real key, uncomment and fill:
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
